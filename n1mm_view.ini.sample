# Change this file name to n1mm_view.ini and put it in ONLY one of the following three locations:
#      ~/.config/n1mm_view.ini
#      ~/n1mm_view.ini
#      <script directory>/n1mm_view.ini
# If you have the file in more than one of those locations, the script will abort with an error message.
# This is to avoid multiple ini files making it harder to know where the settings are being read.

# This is where you should set you local options for your site. At a minimum, change the following:
# Under EVENT_INFO,
#   set Name to something like <Your CLub Name> Field Day or WInter Field Day
#   set the START_TIME and END_TIME
#   set you QTH_ coordinates if you want to see a pin on the map
# Optionally, set the LOGO_FILENAME to the proper logo
#    For Winter Field Day, wget https://winterfieldday.org/img/wfda_logo.png
#    For ARRL Field Day, grab the new logo each year
#    If you are using the headless.py script to generate graphics to load to your website, 
#    modify the POST_FILE_COMMAND to rsync the files or run a script if you want to do multiple steps.
#    If you use a script like postCommands.sh, make it executable with chmod +x postCommands.sh



[GLOBAL]
DATABASE_FILENAME = n1mm_view.db
DISPLAY_DWELL_TIME = 6
DATA_DWELL_TIME = 60
HEADLESS_DWELL_TIME = 120
LOG_LEVEL = INFO
LOGO_FILENAME = /home/pi/wfda_logo.png
# MULTS controls which multiplier set to use for the map display.
# Valid values:
#   SECTIONS  - ARRL Field Day sections (North America map)
#   STATES    - US state abbreviations (North America map)
#   ITUZONES  - ITU zones 1-90 (world map; e.g. IARU HF Championship)
#   CQZONES   - CQ zones 1-40 (world map; e.g. CQ WW)
#   GRID      - Maidenhead grid squares (VHF/UHF contests). Each worked grid's
#               cell is computed from its locator and coloured; the map auto-fits
#               to the worked area. Precision follows the logged grid (4 or 6
#               char). Progress/Remaining charts are auto-disabled (no fixed total).
# Zone fill polygons live in shapes/itu_zones.geojson and shapes/cq_zones.geojson,
# generated by utils/extract_zones.py from the Leaflet.ITUzones / Leaflet.CQzones data.
MULTS = SECTIONS

[EVENT INFO]
NAME = Field Day
START_TIME = 2025-01-25 15:00:00
END_TIME = 2025-01-26 20:59:59
QTH_LATITUDE = 27.9837941202094249
QTH_LONGITUDE = -82.74670114956339

[N1MM INFO]
BROADCAST_PORT = 12060
BROADCAST_ADDRESS = 192.168.1.255
LOG_FILE_NAME = FD2024-N4N.s3db
; Optional UDP fan-out. If set, the collector re-sends every received N1MM
; datagram verbatim to this port on localhost (127.0.0.1). Useful when a
; second consumer must run on the same host and would otherwise collide on
; BROADCAST_PORT -- e.g. the Club Log gateway started with -n1mmport=12062.
; The logger keeps sending to BROADCAST_PORT only; no double-broadcast.
; 0 or unset disables forwarding.
;UDP_FORWARD_PORT = 12062
; Comma-separated allow-list for the <app> XML field. Messages whose app
; field is NOT in this list are dropped by the collector. Matching is
; case-insensitive. Messages with no <app> field at all are always
; accepted (back-compat). Leave empty to accept any sender.
;   N1MMLogger.Net = N1MM Logger+   TR4W = TR4W   TR4QT = TR4W's QT build
;   DXLab          = DXLab Suite (often emits RadioInfo too)
ALLOWED_APPS = N1MMLogger.Net,TR4W

[HEADLESS INFO]
; Set IMAGE_DIR to None or the name of a directory on the system to write files. Note if using a Pi with an SD card only, use the ramdisk setup in the install process.
; A sample value could be /mnt/ramdisk/n1mm_view/html
IMAGE_DIR = None

; The POST_FILE_COMMAND is used is to execute this command. You can use it to call rsync or a script.
#POST_FILE_COMMAND = rsync -avz /mnt/ramdisk/n1mm_view/html/* user@sshserver:www/n1mm_view/html

[WEBSERVER]
; Built-in Flask server that serves IMAGE_DIR and exposes /api/radio for
; near-realtime radio status. Run via init/n1mm_view_webserver.service.
; Disable if you'd rather serve IMAGE_DIR with Apache or another web server.
ENABLED = True
; 0.0.0.0 listens on every interface (wired + wifi). Use 127.0.0.1 to restrict
; to local only.
BIND = 0.0.0.0
PORT = 8080
; How often the browser polls /api/radio for live updates. Lower = more
; responsive, higher = less load. The PNG sidebar fallback (used by rsync'd
; remote copies) is not affected by this value.
RADIO_POLL_SECONDS = 2

[MAP]
; Appearance of the worked-multiplier map (sections_worked_map.png).
; Colours accept any matplotlib colour spec: '#rrggbb' hex or a name like
; 'navy'. Omit any key to use the default shown. (The worked-zone/section
; choropleth fill is a fixed viridis ramp and is not configured here.)
;
; Base-feature fills. The default land green is quite dark; lighten LAND_COLOR
; (up to white) if the unworked continents are hard to see.
;OCEAN_COLOR = #000080
;LAND_COLOR = #113311
;LAKE_COLOR = #000080
;
; Day/night terminator shading opacity: 0.0 = off (no shading), 1.0 = solid
; black night side. Lower values keep the night hemisphere readable. Default 0.25.
;TERMINATOR_ALPHA = 0.25

[FONT INFO]
# If font seems too big, try 60 for VIEW_FONT and 100 for BIGGER_FONT
VIEW_FONT = 64
BIGGER_FONT = 180

[FEATURES]
# Optional display features - set to True to enable
# Radio Status display showing N1MM radio info
SHOW_RADIO_INFO = False
# Multiplier progress bar showing worked/total mults
SHOW_MULT_PROGRESS = False
# Table of remaining unworked multipliers
SHOW_MULT_REMAINING = False
# Crawl alert when a new multiplier is logged (yellow on red)
SHOW_MULT_ALERT = False
# IARU HF only: HQ-station multiplier roster. Society HQ stations and IARU
# officials send a society abbreviation (ARRL, DARC, IARU, R1, ...) in the
# section field instead of an ITU zone. This slide shows a worked/total count
# with a progress bar over the full ~170-society roster, worked ones in green.
# Coexists with the ITU-zone map (MULTS = ITUZONES); leave False for other
# contests.
SHOW_HQ_STATIONS = False
# IARU HF only: WRTC ("contest within the contest", every four years). ~50 teams
# get special callsigns issued shortly before the start. This slide shows a
# worked/total count with a progress bar over the roster of WRTC callsigns,
# worked ones in green. The callsign list comes from [WRTC] CALLSIGNS_FILE
# below, re-read each cycle so the calls can be dropped in without a restart.
# Only callsigns are shown -- never team names -- per WRTC's anti-cheerleading
# policy. Leave False for other contests.
SHOW_WRTC = False
# Ranked operator leaderboard with positions and percentages
SHOW_OPERATOR_LEADERBOARD = False
# Base count charts (default True). Turn off the ones that don't apply:
#   SHOW_QSOS_BY_STATION  - hide when running a single station
#   SHOW_QSOS_BY_CLASS    - Field Day class; hide for non-FD contests (e.g. IARU)
#   SHOW_QSOS_BY_CATEGORY - Field Day category; hide for non-FD contests
SHOW_QSOS_BY_STATION = True
SHOW_QSOS_BY_CLASS = True
SHOW_QSOS_BY_CATEGORY = True
# Hide radio_info rows older than this many seconds (clears stale entries
# from past test sessions). Set to 0 to disable hiding. The 60-second
# "dim" threshold in the renderer is separate and still applies.
RADIO_HIDE_SECONDS = 600
# Race-curve slide: cumulative distinct operators this year, last year (as a
# reference line), and the "new" subset (this year's ops whose name does not
# appear in PRIOR_DB_FILENAME's operator table). Requires [NEW_OPERATORS] below.
SHOW_NEW_OPS_RACE = False
# Roster slide + sidebar panel listing this year's new operators with their
# first-QSO timestamp, band, mode, and callsign worked.
SHOW_NEW_OPS_ROSTER = False
# Year-over-year bar chart of "new operators per event" in the sidebar AND as
# a carousel slide. Reads PRIOR_OPERATORS_DB (built by utils/import_prior_operators.py)
# and appends the current event as a "live" bar.
SHOW_NEW_OPS_YOY = False

[WRTC]
; Path to a plain-text file listing the WRTC special callsigns (one per line).
; Read fresh on every render cycle, so once the calls are announced you can just
; drop them into this file -- no restart needed. Blank lines and lines starting
; with '#' are ignored. Only the first token on each line is used as the
; callsign; any trailing text is discarded, so team names are never displayed.
; Relative paths resolve from the n1mm_view working directory. Only used when
; SHOW_WRTC = True.
CALLSIGNS_FILE = wrtc2026.txt

[NEW_OPERATORS]
; Path to a prior event's n1mm_view DB. Operators in the current event whose
; name does NOT appear in this DB's operator table are flagged as "new".
; Leave empty to disable comparison (everyone counts as new). For ARRL Field
; Day the natural choice is last year's FD DB.
PRIOR_DB_FILENAME = n1mm_view.2025ARRLFD.db
; Label used for the reference series on the race-curve slide.
PRIOR_EVENT_LABEL = 2025 FD
; Consolidated prior-operators database produced by utils/import_prior_operators.py.
; This is the runtime source for the "not new" lookup AND the YOY bar chart.
; Build / refresh it with:
;     python3 utils/import_prior_operators.py
; The script reads PRIOR_DB_FILENAME, every n1mm_view.*.db in the CWD, and
; every *.adi/*.adif in PRIOR_ADIF_DIR.
PRIOR_OPERATORS_DB = prior_operators.db
; Directory of historical ADIF logs (e.g. logs from 2019-2024) — read ONLY by
; the import script, not on each render. Drop new ADIFs in here and re-run
; the importer when you want them picked up.
PRIOR_ADIF_DIR = priorLogs
; Case-insensitive regex used by the YOY chart to pick which events to plot.
; The default matches ARRL Field Day variants (ARRL-FD, ARRLFD, ARRL FD); use
; e.g. '.' to plot every event in the prior-ops DB.
YOY_EVENT_REGEX = ARRL.?FD

[EXTERNAL_SLIDES]
; Each non-empty line becomes an iframe slide in the carousel. The key is the
; slide title; the value is the URL. Add or remove entries to extend the
; carousel without touching code. The Pi web server is served over plain HTTP,
; so HTTP -> HTTPS iframes work fine, but HTTPS -> HTTP iframes will be blocked
; by the browser. Comment a line out with ';' to disable it.
;
; Caveats with iframe embedding:
;  - Some sites send X-Frame-Options: DENY (e.g. QRZ.com) and refuse to embed
;    at all; those slides will show an "open in new tab" link instead.
;  - ClubLog Livestream uses a WebSocket whose handshake includes the iframe's
;    Origin (this Pi's URL). ClubLog may or may not accept it — if the page
;    sits on "Connecting…" forever, the fallback link is your way in.
;ClubLog Livestream = https://clublog.org/livestream/W4TA
;Solar Conditions = https://www.hamqsl.com/solar.html
